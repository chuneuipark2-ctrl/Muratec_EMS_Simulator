<UserControl x:Class="EMS_TEST_SIMULATOR.UserControl2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="Black">
        <Viewbox Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12,0,0">
        <Canvas x:Name="MainCanvas" Width="800" Height="200">
            <Line X1="50" Y1="65" X2="750" Y2="65" Stroke="#444444" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
            <Line X1="50" Y1="65" X2="750" Y2="65" Stroke="Yellow" StrokeThickness="1" StrokeDashArray="4 2" />

            <StackPanel x:Name="SensorContainer" Orientation="Horizontal" Canvas.Top="100" Canvas.Left="50">
            </StackPanel>

            <Canvas x:Name="RavGroup_SR150">
                <Rectangle Width="60" Height="30" Fill="DarkOrange" RadiusX="5" RadiusY="5" 
                           Stroke="White" StrokeThickness="2" Canvas.Top="50" Canvas.Left="-30"/>

                <TextBlock Text="SR150" Foreground="White" FontWeight="Bold" FontSize="11" 
                           Canvas.Top="58" Canvas.Left="-18"/>

                <Canvas.RenderTransform>
                    <TranslateTransform x:Name="RavTransform_SR150" X="50" Y="0" />
                </Canvas.RenderTransform>
            </Canvas>
        </Canvas>
        </Viewbox>
    </Grid>
</UserControl>