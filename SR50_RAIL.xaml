<UserControl x:Class="EMS_TEST_SIMULATOR.UserControl1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <Grid Background="Black">
        <Viewbox Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12,0,0">
        <Canvas x:Name="MainCanvas" Width="800" Height="200">

            <Line X1="50" Y1="65" X2="750" Y2="65" 
                  Stroke="#444444" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />

            <Line X1="50" Y1="65" X2="750" Y2="65" 
                  Stroke="Yellow" StrokeThickness="1" StrokeDashArray="4 2" />

            <StackPanel x:Name="SensorContainer" Orientation="Horizontal" Canvas.Top="100" Canvas.Left="50">
            </StackPanel>

            <Canvas x:Name="RavGroup">

                <Canvas Width="40" Height="20" Canvas.Top="54" Canvas.Left="-17">
                    <Rectangle Fill="Yellow" Width="40" Height="20" RadiusX="2" RadiusY="2" Stroke="White"/>
                    <TextBlock Text="SR50" Foreground="Black" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,3,0,0"/>
                </Canvas>

                <Canvas.RenderTransform>
                    <TranslateTransform x:Name="MovingTransform" X="50" Y="0" />
                </Canvas.RenderTransform>
            </Canvas>

        </Canvas>
        </Viewbox>
    </Grid>
</UserControl>